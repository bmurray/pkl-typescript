/// Generates TypeScript sources from Pkl modules.
@ModuleInfo { minPklVersion = "0.31.0" }
module pkl.typescript.Generator

import "pkl:reflect"

import "GeneratorSettings.pkl"
import "internal/gatherer.pkl"
import "internal/TsMapping.pkl"
import "internal/ClassGen.pkl"
import "internal/EnumGen.pkl"
import "internal/Gen.pkl"
import "internal/utils.pkl"

/// Settings to control code generation.
codegenSettings: GeneratorSettings

/// The module that should be generated.
moduleToGenerate: Module

typealias EnumMember = reflect.StringLiteralType | reflect.NothingType

/// Check if a type declaration is an enum-like string literal union.
// noinspection TypeMismatch
function isEnumLike(decl: reflect.TypeDeclaration) =
  decl is reflect.TypeAlias
    && let (referent = decl.referent)
      referent is reflect.UnionType
        && referent.members.every((t) -> t is EnumMember)
        && referent.members
          .filter((t) -> t is reflect.StringLiteralType)
          .every((it: reflect.StringLiteralType) -> utils.canBeNormalizedToEnumName(it.value))
        && referent.members
          .filter((t) -> t is reflect.StringLiteralType)
          .map((it: reflect.StringLiteralType) -> utils.normalizeEnumName(it.value))
          .isDistinct

/// Gather enum-like type aliases.
function gatherEnums(decl: List<reflect.TypeDeclaration>): List<TsMapping> =
  decl
    .filter((it) -> isEnumLike(it))
    .fold(List(), (acc, it) ->
      acc.add(new TsMapping.Enum {
        source = it
        seenMappings = acc
      })
    )

/// Gather classes.
///
/// If the module companion class would produce the same name as an inner class,
/// the companion class is skipped (the inner class takes precedence).
function gatherClasses(decl: List<reflect.TypeDeclaration>): Mixin<List<TsMapping>> = (acc) ->
  let (
    companionConflicts =
      decl
        .filter((it) -> it is reflect.Class && it.enclosingDeclaration.moduleClass == it)
        .filter((companion) ->
          decl.any((other) ->
            other is reflect.Class
              && other != companion
              && other.enclosingDeclaration.moduleClass != other
              && utils.toTsTypeName(other) == utils.toTsTypeName(companion)
          )
        )
  )
    decl
      .filter((it) -> it is reflect.Class && !companionConflicts.contains(it))
      .fold(acc, (accum, it) ->
        accum.add(new TsMapping.Class {
          source = it
          seenMappings = accum
        })
      )

local allMappings: List<TsMapping> =
  let (clazz = reflect.Module(moduleToGenerate).moduleClass)
  let (declarations = gatherer.gatherTypeDeclarations(clazz, List()))
    gatherEnums(declarations) |> gatherClasses(declarations)

local moduleMirror = reflect.Module(moduleToGenerate)

/// Mappings for types declared in this module.
local localMappings: List<TsMapping> =
  allMappings.filter((it) -> utils.isLocalDeclaration(it.source, moduleMirror))

/// Mappings for types from imported modules.
local externalMappings: List<TsMapping> =
  allMappings.filter((it) -> !utils.isLocalDeclaration(it.source, moduleMirror))

/// Group external mappings by their source module to generate import statements.
local importStatements: String =
  let (
    // Group external types by source module URI
    byModule = externalMappings.groupBy((it) -> it.source.enclosingDeclaration.uri)
  )
    if (byModule.isEmpty)
      ""
    else
      byModule
        .mapValues((_uri, mappings: List<TsMapping>) ->
          let (moduleName = mappings.first.source.enclosingDeclaration.name)
          let (fileStem = utils.moduleFileNameStem(moduleName))
          let (names = mappings.map((m) -> m.name).distinct.sort())
            "import type { \(names.join(", ")) } from \"./\(fileStem).pkl\";"
        )
        .values
        .join("\n")

local function hasUniqueNames(): Boolean =
  let (names = localMappings.map((it) -> it.name))
    if (names.isDistinct)
      true
    else
      let (
        duplicateNames =
          localMappings.filter((it) -> localMappings.count((m) -> m.name == it.name) > 1)
      )
        throw(
          """
          Conflict: multiple Pkl declarations compute to TypeScript name `\(duplicateNames.first.name)`.

          To resolve this conflict, add a `@ts.Name` annotation to any of the conflicting declarations.

          For example:

          ```
          @ts.Name { value = "CrabCakes" }
          class Crab_Cakes
          ```
          """
        )

local generated: List<Gen>(hasUniqueNames()) =
  localMappings.map((it) ->
    if (it is TsMapping.Class)
      new ClassGen {
        mappings = allMappings
        mapping = it
      }
    else
      new EnumGen {
        mappings = allMappings
        mapping = it
      })

local fileName: String =
  let (lastPart = moduleMirror.name.split(".").last)
  let (first = lastPart[0].toLowerCase())
    first + lastPart.drop(1) + ".pkl.ts"

local fileContents: String =
  new Listing {
    utils.renderHeaderComment(moduleMirror)
    ""
    when (!importStatements.isEmpty) {
      importStatements
      ""
    }
    for (gen in generated) {
      gen.contents
    }
  }.join("\n")

output {
  files {
    [fileName] {
      text = fileContents
    }
  }
  text = throw("Generator.pkl only produces multiple-file output. Try running again with the -m flag.")
}
